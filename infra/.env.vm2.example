# =============================================================================
# infra/.env.vm2.example — Environment template for VM2 (submit-vm)
#
# Copy to infra/.env.vm2 and replace REPLACE_WITH_VM1_PRIVATE_IP
# with the actual private IP of VM1 (e.g. 10.0.1.4).
#
# This file is copied to ~/co3404/.env on VM2 by infra/deploy.sh.
# Never commit the filled-in .env.vm2 to git.
# =============================================================================

# ── RabbitMQ (local to VM2 — Docker service name is "rabbitmq") ──────────────
# SECURITY: Change from the default 'guest' credentials before production deployment.
RABBITMQ_USER=REPLACE_WITH_RABBITMQ_USER
RABBITMQ_PASSWORD=REPLACE_WITH_RABBITMQ_PASSWORD

# Note: JOKE_SERVICE_URL is NOT required for Option 4.
# submit-service receives joke types via ECST (the sub_type_update RabbitMQ queue)
# published by the ETL service on VM1 after each new type is inserted.

# ── Public Gateway URL ──────────────────────────────────────────────────
# REQUIRED for production: set this to the Kong public IP so that:
#   1. The Swagger UI defaults to the correct Azure server (not localhost)
#      (fixes Swagger "Try it out" failing with connection refused - BUG-H8)
#   2. The submit-service frontend routes API calls through Kong
#      (rate limiting, correlation-ID headers, etc.)
# Get the value from: terraform -chdir=infra/terraform output -raw kong_public_ip
# e.g. PUBLIC_GATEWAY_BASE=https://85.211.240.162
PUBLIC_GATEWAY_BASE=https://REPLACE_WITH_KONG_PUBLIC_IP
# ── Docker Hub image for submit-service ────────────────────────────────────────────
# The GitHub Actions workflow deploy-submit.yml builds and pushes this image
# on every push to main. Set to your Docker Hub username below.
# The :latest tag is always the most recent successful build.
# To pin to a specific commit: use SUBMIT_IMAGE=username/submit-service:<sha>
SUBMIT_IMAGE=REPLACE_WITH_DOCKERHUB_USERNAME/submit-service:latest
