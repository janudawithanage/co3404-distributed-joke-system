# =====================================================
# CO3404 Distributed Systems – Environment Variables
# Phase 1: Local Docker Development
# =====================================================
# Copy to .env and adjust if needed.
# These values are used by docker-compose for variable substitution.

# ── MySQL ─────────────────────────────────────────
DB_HOST=mysql
DB_USER=jokeuser
DB_PASSWORD=jokepassword
DB_NAME=jokesdb
DB_ROOT_PASSWORD=rootpassword

# ── RabbitMQ ──────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ── Internal Service URLs (Docker network DNS) ────
# Services communicate using container names, not localhost.
# This is how Docker's built-in DNS works on a bridge network.
JOKE_SERVICE_URL=http://joke-service:3001