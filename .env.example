# CO3404 Distributed Systems - Environment Variables (Option 4)
# Copy to .env and fill in values. NEVER commit .env to git.

DB_TYPE=mysql
DB_HOST=mysql
DB_USER=jokeuser
DB_PASSWORD=jokepassword
DB_NAME=jokesdb
DB_ROOT_PASSWORD=rootpassword

MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=mongopassword
MONGO_URI=mongodb://admin:mongopassword@mongodb:27017/jokesdb?authSource=admin

RABBITMQ_HOST=rabbitmq
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

AUTH0_SECRET=REPLACE_WITH_LONG_RANDOM_STRING
# BASE_URL must be the public URL users access through Kong (port 8000 locally).
# Auth0 Allowed Callback URL: http://localhost:8000/callback
# Auth0 Allowed Logout URL:   http://localhost:8000
AUTH0_BASE_URL=http://localhost:8000
AUTH0_CLIENT_ID=REPLACE_WITH_AUTH0_CLIENT_ID
AUTH0_CLIENT_SECRET=REPLACE_WITH_AUTH0_CLIENT_SECRET
AUTH0_ISSUER_BASE_URL=https://YOUR_TENANT.auth0.com

DOCKER_IMAGE=your-dockerhub-username/moderate-service:latest
