# CO3404 Distributed Systems - Environment Variables (Option 4)
# Copy to .env and fill in values. NEVER commit .env to git.

DB_TYPE=mysql
DB_HOST=mysql
DB_USER=jokeuser
DB_PASSWORD=jokepassword
DB_NAME=jokesdb
DB_ROOT_PASSWORD=rootpassword

MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=mongopassword
MONGO_URI=mongodb://admin:mongopassword@mongodb:27017/jokesdb?authSource=admin

RABBITMQ_HOST=rabbitmq
# ⚠️  SECURITY: 'guest' credentials are for local Docker Compose only.
#     Set real credentials in infra/.env.vm1 and infra/.env.vm2 before any deployment.
#     RabbitMQ blocks guest logins from remote IPs by default, but don't rely on this.
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ── Public Gateway (used by joke-service homepage JS) ──────────
# Routes all frontend API calls via Kong for rate limiting, correlation IDs, etc.
PUBLIC_GATEWAY_BASE=http://localhost:8000

# ── Auth0 (Moderate Service) ────────────────────────────────────
#
# ╔══════════════════════════════════════════════════════════════════════╗
# ║  SECURITY — READ BEFORE DEPLOYING                                  ║
# ╠══════════════════════════════════════════════════════════════════════╣
# ║  AUTH_ENABLED=false   →  SAFE for LOCAL DOCKER COMPOSE ONLY.       ║
# ║  With this value the moderation API is open to any network peer.   ║
# ║                                                                    ║
# ║  For ANY public-facing / shared / Azure deployment you MUST:       ║
# ║    1. Remove AUTH_ENABLED=false (or set it to true)                ║
# ║    2. Fill in all AUTH0_* values with real credentials             ║
# ║    3. See README.md §Auth0 Setup for step-by-step instructions     ║
# ║                                                                    ║
# ║  The service automatically falls back to open mode if AUTH0_*      ║
# ║  still contain REPLACE_WITH_* placeholders — it will log a loud    ║
# ║  WARNING but will NOT refuse to start.                             ║
# ╚══════════════════════════════════════════════════════════════════════╝
#
# Auth0 Allowed Callback URLs: http://localhost:8000/callback
#                              https://<KONG_IP>/callback
# Auth0 Allowed Logout URLs:   http://localhost:8000/moderate-ui
#                              https://<KONG_IP>/moderate-ui
# Generate AUTH0_SECRET with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_ENABLED=false
AUTH0_SECRET=REPLACE_WITH_LONG_RANDOM_STRING
AUTH0_BASE_URL=http://localhost:8000
AUTH0_CLIENT_ID=REPLACE_WITH_AUTH0_CLIENT_ID
AUTH0_CLIENT_SECRET=REPLACE_WITH_AUTH0_CLIENT_SECRET
AUTH0_ISSUER_BASE_URL=https://YOUR_TENANT.auth0.com

# Optional role-based moderation authorization (used when AUTH_ENABLED=true)
# MODERATOR_ROLE=moderator
# AUTH0_ROLES_CLAIM=https://your-namespace.example.com/roles

DOCKER_IMAGE=your-dockerhub-username/moderate-service:latest
