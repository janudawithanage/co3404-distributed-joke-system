# =============================================================================
# infra/.env.vm3.example — Environment template for VM3 (moderate-vm)
#
# Copy to infra/.env.vm3 and fill in all REPLACE_WITH_* values.
# This file is copied to ~/moderate/.env on VM3 by infra/deploy.sh
# (or automatically by GitHub Actions CI/CD).
#
# Never commit the filled-in .env.vm3 to git.
# =============================================================================

# ── Docker Hub image (used by vm3-compose.yml) ────────────────────────────────
# Set to your Docker Hub username/image pushed by GitHub Actions.
# e.g. DOCKER_IMAGE=myusername/moderate-service:latest
DOCKER_IMAGE=REPLACE_WITH_DOCKERHUB_USERNAME/moderate-service:latest

# ── RabbitMQ (running on VM2 — must use VM2's private IP) ────────────────────
# The moderate-service on VM3 connects to RabbitMQ on VM2 via the Azure VNet.
# e.g. RABBITMQ_HOST=10.0.1.5
RABBITMQ_HOST=REPLACE_WITH_VM2_PRIVATE_IP
# SECURITY: Must match the credentials configured in VM2's docker-compose RABBITMQ_USER/PASSWORD.
RABBITMQ_USER=REPLACE_WITH_RABBITMQ_USER
RABBITMQ_PASSWORD=REPLACE_WITH_RABBITMQ_PASSWORD

# ── Auth0 OpenID Connect credentials (BUG-H6 fix) ────────────────────────────
# Without real Auth0 credentials the service runs in unauthenticated mode:
# anyone with the /moderate-ui URL can approve/reject jokes.
#
# To ENABLE authentication:
#   1. Create a "Regular Web Application" at https://manage.auth0.com
#   2. In Auth0 Application Settings set:
#        Allowed Callback URLs:  https://<KONG_PUBLIC_IP>/callback
#        Allowed Logout URLs:    https://<KONG_PUBLIC_IP>/moderate-ui
#   3. Copy Client ID, Client Secret, and Domain below.
#   4. AUTH0_BASE_URL must be exactly the public URL users browse to (Kong IP).
#      Do NOT add a path suffix — OIDC builds callback as baseURL + /callback.
#   5. Generate AUTH0_SECRET with:
#        node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# NOTE: If any value below is still REPLACE_WITH_*, auth is automatically
# disabled regardless of AUTH_ENABLED value (safe fallback for demos).
AUTH0_SECRET=REPLACE_WITH_32PLUS_CHAR_RANDOM_STRING
AUTH0_BASE_URL=https://REPLACE_WITH_KONG_PUBLIC_IP
AUTH0_CLIENT_ID=REPLACE_WITH_AUTH0_CLIENT_ID
AUTH0_CLIENT_SECRET=REPLACE_WITH_AUTH0_CLIENT_SECRET
AUTH0_ISSUER_BASE_URL=https://REPLACE_WITH_YOUR_TENANT.auth0.com

# Optional: enforce moderator role when Auth0 is enabled
# MODERATOR_ROLE=moderator
# AUTH0_ROLES_CLAIM=https://your-namespace.example.com/roles

# ── Auth operating mode ──────────────────────────────────────────────
# The service has three operating modes depending on env var values:
#
#   MODE 'oidc'         → AUTH0_* are real credentials (not REPLACE_WITH_*)
#                         → Auth0 login is REQUIRED to access the moderation UI
#                         → GET /me and POST /moderated require a valid session
#
#   MODE 'dev'          → AUTH_ENABLED=false is explicitly set
#                         → Passthrough — for local Docker Compose only
#                         → Never use in production
#
#   MODE 'unconfigured' → AUTH0_* still have REPLACE_WITH_* placeholder values
#                         → Passthrough WITH a console warning and UI banner
#                         → Anyone with the URL can moderate — fix before demo!
#
# ⚠️  If you deploy to Azure WITHOUT filling in AUTH0_* values below, the service
#     runs in 'unconfigured' mode and the moderation UI is publicly accessible.
#     Fill in all AUTH0_* values to enable full authentication (BUG-H6 fix).
#
# To verify the active mode post-deploy:
#   curl https://<KONG_IP>/auth-status
#   Expected: { "authEnabled": true, "mode": "oidc" }
