# =============================================================================
# infra/.env.vm3.example — Environment template for VM3 (moderate-vm)
#
# Copy to infra/.env.vm3 and fill in all REPLACE_WITH_* values.
# This file is copied to ~/moderate/.env on VM3 by infra/deploy.sh
# (or automatically by GitHub Actions CI/CD).
#
# Never commit the filled-in .env.vm3 to git.
# =============================================================================

# ── Docker Hub image (used by vm3-compose.yml) ────────────────────────────────
# Set to your Docker Hub username/image pushed by GitHub Actions.
# e.g. DOCKER_IMAGE=myusername/moderate-service:latest
DOCKER_IMAGE=REPLACE_WITH_DOCKERHUB_USERNAME/moderate-service:latest

# ── RabbitMQ (running on VM2 — must use VM2's private IP) ────────────────────
# The moderate-service on VM3 connects to RabbitMQ on VM2 via the Azure VNet.
# e.g. RABBITMQ_HOST=10.0.1.5
RABBITMQ_HOST=REPLACE_WITH_VM2_PRIVATE_IP
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ── Auth0 OpenID Connect credentials ─────────────────────────────────────────
# Create a Regular Web Application at https://auth0.com
# Set the following in the Auth0 dashboard before filling in below:
#   Allowed Callback URLs: https://<KONG_PUBLIC_IP>/callback
#   Allowed Logout URLs:   https://<KONG_PUBLIC_IP>
#
# AUTH0_BASE_URL must be the PUBLIC URL users browse to (through Kong).
# It must match exactly what is in Auth0 Allowed Callback URLs.
AUTH0_SECRET=REPLACE_WITH_32PLUS_CHAR_RANDOM_STRING
AUTH0_BASE_URL=https://REPLACE_WITH_KONG_PUBLIC_IP
AUTH0_CLIENT_ID=REPLACE_WITH_AUTH0_CLIENT_ID
AUTH0_CLIENT_SECRET=REPLACE_WITH_AUTH0_CLIENT_SECRET
AUTH0_ISSUER_BASE_URL=https://REPLACE_WITH_YOUR_TENANT.auth0.com
