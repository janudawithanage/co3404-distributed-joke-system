# =============================================================================
# infra/.env.vm2.example — Environment template for VM2 (submit-vm)
#
# Copy to infra/.env.vm2 and replace REPLACE_WITH_VM1_PRIVATE_IP
# with the actual private IP of VM1 (e.g. 10.0.1.4).
#
# This file is copied to ~/co3404/.env on VM2 by infra/deploy.sh.
# Never commit the filled-in .env.vm2 to git.
# =============================================================================

# ── RabbitMQ (local to VM2 — Docker service name is "rabbitmq") ──────────────
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ── Joke Service URL (running on VM1 — must use VM1's private IP) ────────────
# The Submit service on VM2 proxies GET /types to the Joke service on VM1.
# Replace REPLACE_WITH_VM1_PRIVATE_IP with the actual value from the portal.
# e.g.: JOKE_SERVICE_URL=http://10.0.1.4:3000
JOKE_SERVICE_URL=http://REPLACE_WITH_VM1_PRIVATE_IP:3000
