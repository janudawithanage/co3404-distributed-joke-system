# =============================================================================
# infra/.env.vm1.example — Environment template for VM1 (joke-vm)
#
# Copy to infra/.env.vm1 and replace REPLACE_WITH_VM2_PRIVATE_IP
# with the actual private IP of VM2 (e.g. 10.0.1.5).
#
# This file is copied to ~/co3404/.env on VM1 by infra/deploy.sh.
# Never commit the filled-in .env.vm1 to git.
# =============================================================================

# ── Database type (mysql or mongo) ────────────────────────────────────────────
# Set to 'mongo' and provide MONGO_URI to switch to MongoDB.
DB_TYPE=mysql

# ── MySQL (local to VM1 — Docker service name is "mysql") ────────────────────
DB_HOST=mysql
DB_USER=jokeuser
DB_PASSWORD=jokepassword
DB_NAME=jokesdb
DB_ROOT_PASSWORD=rootpassword

# ── MongoDB (only used when DB_TYPE=mongo) ────────────────────────────────────
# MONGO_URI=mongodb://admin:mongopassword@mongodb:27017/jokesdb?authSource=admin

# ── RabbitMQ (running on VM2 — must use VM2's private IP) ────────────────────
# The ETL service on VM1 connects to RabbitMQ on VM2 via the Azure VNet.
# Replace REPLACE_WITH_VM2_PRIVATE_IP with the actual value from the portal
# e.g.: RABBITMQ_HOST=10.0.1.5
RABBITMQ_HOST=REPLACE_WITH_VM2_PRIVATE_IP
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ── Public Gateway URL (used by joke-service homepage JS) ─────────────────────────────
# Set to the Kong public IP so all frontend API calls route via Kong
# (rate limiting, correlation-ID headers, etc.).
# Get the value from: terraform -chdir=infra/terraform output -raw kong_public_ip
# e.g. PUBLIC_GATEWAY_BASE=https://85.211.240.162
PUBLIC_GATEWAY_BASE=https://REPLACE_WITH_KONG_PUBLIC_IP
